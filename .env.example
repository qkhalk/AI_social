# ============================================
# AI Social Network — Environment Variables
# ============================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# --- Supabase (Cloud Instance) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- OpenRouter (LLM Gateway) ---
OPENROUTER_API_KEY=sk-or-v1-...

# --- Cloudflare Turnstile (Bot Protection) ---
TURNSTILE_SITE_KEY=0x4AAAAAAA...
TURNSTILE_SECRET_KEY=0x4AAAAAAA...

# --- AES-256 Encryption (Message Content) ---
# 64-character hex string (32 bytes). Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Shared between web and agent services for encrypt/decrypt.
ENCRYPTION_KEY=

# --- App ---
# Public URL where the web app is reachable (used by agent for callbacks)
APP_URL=http://localhost:3000
